string ConvertRecordToOneLine(stClintData Client, string separator = "#//#") {

	string ClientRecord = "";
	ClientRecord += Client.AccountNumber + separator;
	ClientRecord += Client.PinCode + separator;
	ClientRecord += Client.Name + separator;
	ClientRecord += Client.phone + separator;
	ClientRecord += to_string(Client.AccountBalance);
	return ClientRecord;
}

void AddClientToFile(string	FileName, string stDataLine) {

	fstream MyFile;
	MyFile.open(FileName, ios::out | ios::app);

	if (MyFile.is_open())
	{
		MyFile << stDataLine << "\n";
	}
	MyFile.close();
}

void AddClient() {
	stClintData Client;
	Client = ReadClientInfo();
	AddClientToFile(ClientsFileName, ConvertRecordToOneLine(Client));
}

