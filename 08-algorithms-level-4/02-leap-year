#include <iostream>
#include <string>
using namespace std;

short ReadYear() {
	short Year;
	cout << "Please enter The Year ? ";
	cin >> Year;
	return Year;
}

bool IsLeapYear(short Year) {


	if (Year % 400 == 0 )
	{
		return true;
	}
	else if (Year % 4 == 0 && Year % 100 != 0)
	{
		return true;
	}
	else
		return false;
}


int main()
{
	short Year = ReadYear();

	if (IsLeapYear(Year))
	{
		cout << "\nYes, Year [" << Year << "] Is a leap year. ";

	}
	else
		cout << "\nNo, Year [" << Year << "] Is NOT a leap year. ";
}
